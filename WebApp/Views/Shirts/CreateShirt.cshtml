@using Web_API_Demo.Model;

@model Shirt

<h3>Create Shirt</h3>
<br/>
<form method="post" asp-action="Createshirt">
    <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Brand" class="col-form-label"></label>
        </div>
        <div>
            <input type="text" asp-for="Brand" class="form-control" />
        </div>
    </div>
    <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Colour" class="col-form-label"></label>
        </div>
        <div>
            <input type="text" asp-for="Colour" class="form-control" />
        </div>
    </div>
    <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Size" class="col-form-label"></label>
        </div>
        <div>
            <input type="text" asp-for="Size" class="form-control" min="1" />
        </div>
    </div>
    <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Sex" class="col-form-label"></label>
        </div>
        <div>
            <input type="text" asp-for="Sex" class="form-control" />
        </div>
    </div>
    @* <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Price" class="col-form-label"></label>
        </div>
        <div>
            <input type="text" asp-for="Price" class="form-control" min="" />
        </div>
    </div> *@
    <div class="mb-3 row">
        <div class="col-2">
            <input type="submit" class="btn btn-primary" value="Submit" />
        </div>
    </div>
</form>