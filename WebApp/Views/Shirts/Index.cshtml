@using Web_API_Demo.Model

@model List<Shirt>

<h3>Shirts</h3>
<br/>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Brand</th>
            <th>Sex</th>
            <th>Colour</th>
            <th>Size</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var shirt in Model)
        {
            <tr>
                <td>@shirt.Id</td>
                <td>@shirt.Brand</td>
                <td>@shirt.Sex</td>
                <td>@shirt.Colour</td>
                <td>@shirt.Size</td>
                <td></td>
                <td>
                    <a class="btn btn-link" asp-controller="Shirts" asp-action="EditShirt" asp-route-shirtId="@shirt.Id">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<br/>
<a class="btn btn-primary" asp-controller="Shirts" asp-action="createshirt">Add Shirt</a>