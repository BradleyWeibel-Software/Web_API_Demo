@using Web_API_Demo.Model;

@model Shirt

<h3>Update Shirt</h3>
<br />
<form method="post" asp-action="EditShirt">
    <div class="text-danger" asp-validation-summary="All"></div>
    <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Id" class="col-form-label"></label>
        </div>
        <div class="col-6">
            <input type="text" disabled asp-for="Id" class="form-control" />
            <input type="text" hidden asp-for="Id" />
        </div>
    </div>
    <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Brand" class="col-form-label"></label>
        </div>
        <div class="col-6">
            <input type="text" asp-for="Brand" class="form-control" />
        </div>
        <div class="col-2">
            <span class="text-danger" asp-validation-for="Brand"></span>
        </div>
    </div>
    <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Colour" class="col-form-label"></label>
        </div>
        <div class="col-6">
            <input type="text" asp-for="Colour" class="form-control" />
        </div>
        <div class="col-2">
            <span class="text-danger" asp-validation-for="Colour"></span>
        </div>
    </div>
    <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Size" class="col-form-label"></label>
        </div>
        <div class="col-6">
            <input type="text" asp-for="Size" class="form-control" min="1" />
        </div>
        <div class="col-2">
            <span class="text-danger" asp-validation-for="Size"></span>
        </div>
    </div>
    <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Sex" class="col-form-label"></label>
        </div>
        <div class="col-6">
            <input type="text" asp-for="Sex" class="form-control" />
        </div>
        <div class="col-2">
            <span class="text-danger" asp-validation-for="Sex"></span>
        </div>
    </div>
    @* <div class="mb-3 row">
        <div class="col-2">
            <label asp-for="Price" class="col-form-label"></label>
        </div>
        <div>
            <input type="text" asp-for="Price" class="form-control" min="" />
        </div>
    </div> *@
    <div class="mb-3 row">
        <div class="col-2">
            <input type="submit" class="btn btn-primary" value="Update" />
        </div>
    </div>
</form>